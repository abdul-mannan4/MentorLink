# Server port (Railway sets this automatically, default 5000 for local)
PORT=5000

# Supabase credentials — copy from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Your deployed Vercel frontend URL (set AFTER frontend is deployed)
FRONTEND_URL=https://your-app.vercel.app
