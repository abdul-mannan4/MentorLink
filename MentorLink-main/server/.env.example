PORT=5000
SUPABASE_URL=https://your-project.supabase.co

# Use the SERVICE ROLE key (NOT the anon key) — required for admin.listUsers()
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_KEY=your-supabase-SERVICE-ROLE-key

# Your Vercel frontend URL — used to build the email verification redirect link
# Example: https://mentor-link-xxx.vercel.app
FRONTEND_URL=https://your-app.vercel.app
